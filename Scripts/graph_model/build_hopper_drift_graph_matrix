#!/usr/bin/env python3
from pathlib import Path
import pandas as pd

BASE = Path("/work/users/k/a/katlyssa/Sample BED files")
FULL_MATRIX = BASE / "drift_feature_matrix.tsv"
HOPPER = BASE / "drift_hopper_nodes.tsv"
OUT = BASE / "drift_hopper_feature_matrix.tsv"

print("Loading full drift matrix...")

full_df = pd.read_csv(FULL_MATRIX, sep="\t")

print("Loading Hopper nodes..."

hopper_df = pd.read_csv(HOPPER, sep="\t")
hopper_set = set(hopper_df["ont_cpg"].astype(str))

print(f"Hopper CpGs: {len(hopper_set)}")

full_df["ont_cpg"] = full_df["ont_cpg"].astype(str)
sub = full_df[full_df["ont_cpg"].isin(hopper_set)].copy()

# keep matrix rows in Hopper order
sub = sub.set_index("ont_cpg")
sub = sub.loc[hopper_df["ont_cpg"]]
sub = sub.reset_index()

print("Subset shape:", sub.shape)

sub.to_csv(OUT, sep="\t", index=False)

print(f"Saved Hopper feature matrix to: {OUT}")
