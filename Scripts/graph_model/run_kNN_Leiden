#!/usr/bin/env python3
from pathlib import Path
import pandas as pd
import numpy as np
from sklearn.preprocessing import StandardScaler
from sklearn.neighbors import NearestNeighbors
import igraph as ig
import leidenalg

BASE = Path("/work/users/k/a/katlyssa/Sample BED files")
INPUT = BASE / "drift_hopper_feature_matrix.tsv"
OUT_EDGES = BASE / "drift_knn_edges.tsv"
OUT_MODULES = BASE / "drift_leiden_modules.tsv"

K = 10

RESOLUTION = 1.0

print(f"Reading Hopper feature matrix: {INPUT}")

df = pd.read_csv(INPUT, sep="\t")

cpg_ids = df["ont_cpg"].astype(str).tolist()
feature_cols = [c for c in df.columns if c.startswith("meth_basic_")]

print("Feature columns:", feature_cols)

X = df[feature_cols].copy()

# drop any CpGs with missing values just in case
mask = ~X.isna().any(axis=1)
X = X.loc[mask].copy()
kept_ids = [cpg_ids[i] for i, keep in enumerate(mask) if keep]

print("Matrix shape after NA filter:", X.shape)
            
# standardize sample columns
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

# kNN graph
nbrs = NearestNeighbors(n_neighbors=K + 1, metric="euclidean")
nbrs.fit(X_scaled)
distances, indices = nbrs.kneighbors(X_scaled)

edges = []
weights = []

for i in range(X_scaled.shape[0]):
    for j_idx in range(1, K + 1):  # skip self neighbor at 0
        j = indices[i, j_idx]
        d = distances[i, j_idx]
        # convert distance to similarity weight
        w = 1.0 / (1.0 + d)
        edges.append((i, j))
        weights.append(w)

# build igraph graph
g = ig.Graph(n=X_scaled.shape[0], edges=edges, directed=False)
g.es["weight"] = weights
g.vs["ont_cpg"] = kept_ids
            
# Leiden clustering
partition = leidenalg.find_partition(
    g,
    leidenalg.RBConfigurationVertexPartition,
    weights=g.es["weight"],
    resolution_parameter=RESOLUTION
)

membership = partition.membership

modules = pd.DataFrame({
    "ont_cpg": kept_ids,
    "module": membership
})

modules.to_csv(OUT_MODULES, sep="\t", index=False)

# save edge list with CpG IDs
edge_rows = []
            
for e, w in zip(edges, weights):
    edge_rows.append({
        "source": kept_ids[e[0]],
        "target": kept_ids[e[1]],
        "weight": w
    })

edges_df = pd.DataFrame(edge_rows)
edges_df.to_csv(OUT_EDGES, sep="\t", index=False)

print(f"Saved edges to: {OUT_EDGES}")
print(f"Saved modules to: {OUT_MODULES}")
print("\nModule counts:")
print(modules["module"].value_counts().sort_index())
